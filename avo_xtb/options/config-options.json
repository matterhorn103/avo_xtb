      "none",
      "acetone",
      "acetonitrile",
      "aniline",
      "benzaldehyde",
      "benzene",
      "ch2cl2",
      "chcl3",
      "cs2",
      "dioxane",
      "dmf",
      "dmso",
      "ether",
      "ethylacetate",
      "furane",
      "hexandecane",
      "hexane",
      "methanol",
      "nitromethane",
      "octanol",
      "woctanol",
      "phenol",
      "toluene",
      "thf",
      "water"
